---
source: crates/fai-syntax/src/parser.rs
expression: "dump(indoc!\n{r#\"\n                    module Math\n                    let classify n =\n                      if n < 0 then \"neg\"\n                      else if n = 0 then \"zero\"\n                      else \"pos\"\"#})"
---
module Math
(let Private classify [(pvar n)] (block [] (if (infix < (var n) (int 0)) (string "neg") (if (infix = (var n) (int 0)) (string "zero") (string "pos")))))
