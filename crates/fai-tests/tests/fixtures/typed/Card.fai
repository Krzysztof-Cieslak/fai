module Card

// A playing card modeled with algebraic data types: `Rank` and `Suit` are
// enumerations and a `Card` is a record pairing them. The ranks are declared in
// ascending order, so the *structural* ordering (`<`, `>`) compares them
// correctly — `Ace` is the highest rank with no arithmetic at all. `Card` is a
// transparent alias, so public signatures render as the structural record it
// stands for.

public type Suit =
  | Clubs
  | Diamonds
  | Hearts
  | Spades

public type Rank =
  | Two
  | Three
  | Four
  | Five
  | Six
  | Seven
  | Eight
  | Nine
  | Ten
  | Jack
  | Queen
  | King
  | Ace

public type Card = { rank : Rank, suit : Suit }

// ── Construction & accessors ─────────────────────────────────────────────────

//~ TYPE makeCard : Rank -> Suit -> { rank : Rank, suit : Suit }
public makeCard : Rank -> Suit -> Card
let makeCard rank suit = { rank = rank, suit = suit }

//~ TYPE rank : { rank : Rank, suit : Suit } -> Rank
public rank : Card -> Rank
let rank card = card.rank

//~ TYPE suit : { rank : Rank, suit : Suit } -> Suit
public suit : Card -> Suit
let suit card = card.suit

// ── Numeric values (for deck indexing and display) ───────────────────────────

//~ TYPE rankValue : Rank -> Int
public rankValue : Rank -> Int
let rankValue r =
  match r with
  | Two -> 2
  | Three -> 3
  | Four -> 4
  | Five -> 5
  | Six -> 6
  | Seven -> 7
  | Eight -> 8
  | Nine -> 9
  | Ten -> 10
  | Jack -> 11
  | Queen -> 12
  | King -> 13
  | Ace -> 14

//~ TYPE suitValue : Suit -> Int
public suitValue : Suit -> Int
let suitValue s =
  match s with
  | Clubs -> 0
  | Diamonds -> 1
  | Hearts -> 2
  | Spades -> 3

// ── Comparison helpers (structural equality and ordering on the enums) ───────

//~ TYPE sameRank : { rank : Rank, suit : Suit } -> { rank : Rank, suit : Suit } -> Bool
public sameRank : Card -> Card -> Bool
let sameRank a b = a.rank = b.rank

//~ TYPE sameSuit : { rank : Rank, suit : Suit } -> { rank : Rank, suit : Suit } -> Bool
public sameSuit : Card -> Card -> Bool
let sameSuit a b = a.suit = b.suit

//~ TYPE rankHigher : { rank : Rank, suit : Suit } -> { rank : Rank, suit : Suit } -> Bool
public rankHigher : Card -> Card -> Bool
let rankHigher a b = a.rank > b.rank

// ── Display helpers ──────────────────────────────────────────────────────────

//~ TYPE rankName : Rank -> String
public rankName : Rank -> String
let rankName r =
  match r with
  | Jack -> "J"
  | Queen -> "Q"
  | King -> "K"
  | Ace -> "A"
  | other -> Int.toString (rankValue other)

//~ TYPE suitName : Suit -> String
public suitName : Suit -> String
let suitName s =
  match s with
  | Clubs -> "C"
  | Diamonds -> "D"
  | Hearts -> "H"
  | Spades -> "S"

//~ TYPE cardName : { rank : Rank, suit : Suit } -> String
public cardName : Card -> String
let cardName card = rankName card.rank ++ suitName card.suit

// ── Deck encoding: a card's unique index in a 52-card deck ───────────────────

//~ TYPE cardIndex : { rank : Rank, suit : Suit } -> Int
public cardIndex : Card -> Int
let cardIndex card = (rankValue card.rank - 2) * 4 + suitValue card.suit

// ── Contracts ────────────────────────────────────────────────────────────────

example: rankValue Ace = 14
example: rankValue Two = 2
example: suitValue Clubs = 0
example: suitValue Spades = 3
example: Ace > King
example: Two < Three
example: rankHigher (makeCard Ace Spades) (makeCard King Hearts)
example: cardName (makeCard Ace Spades) = "AS"
example: cardName (makeCard Two Clubs) = "2C"
example: cardName (makeCard Ten Diamonds) = "10D"
example: sameRank (makeCard Ace Spades) (makeCard Ace Hearts)
example: sameSuit (makeCard Ace Hearts) (makeCard Two Hearts)
example: cardIndex (makeCard Two Clubs) = 0
example: cardIndex (makeCard Ace Spades) = 51
forall r: rankValue r >= 2 && rankValue r <= 14
