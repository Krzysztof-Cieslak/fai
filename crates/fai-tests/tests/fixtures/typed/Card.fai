module Card

// A playing card is encoded as a pair (rank, suit) where:
//   rank: 2..14  (2=Two, 11=Jack, 12=Queen, 13=King, 14=Ace)
//   suit: 0..3   (0=Clubs, 1=Diamonds, 2=Hearts, 3=Spades)
// We use plain Int arithmetic so everything stays in the M2 surface.

// ── Card constructors ────────────────────────────────────────────────────────

//~ TYPE makeCard : Int -> Int -> Int * Int
public makeCard : Int -> Int -> Int * Int
let makeCard rank suit = (rank, suit)

//~ TYPE rank : Int * Int -> Int
public rank : Int * Int -> Int
let rank card =
  let (r, s) = card
  r

//~ TYPE suit : Int * Int -> Int
public suit : Int * Int -> Int
let suit card =
  let (r, s) = card
  s

// ── Rank names as integers (named constants) ─────────────────────────────────

//~ TYPE two : Int
public two : Int
let two = 2

//~ TYPE three : Int
public three : Int
let three = 3

//~ TYPE four : Int
public four : Int
let four = 4

//~ TYPE five : Int
public five : Int
let five = 5

//~ TYPE six : Int
public six : Int
let six = 6

//~ TYPE seven : Int
public seven : Int
let seven = 7

//~ TYPE eight : Int
public eight : Int
let eight = 8

//~ TYPE nine : Int
public nine : Int
let nine = 9

//~ TYPE ten : Int
public ten : Int
let ten = 10

//~ TYPE jack : Int
public jack : Int
let jack = 11

//~ TYPE queen : Int
public queen : Int
let queen = 12

//~ TYPE king : Int
public king : Int
let king = 13

//~ TYPE ace : Int
public ace : Int
let ace = 14

// ── Suit names as integers ────────────────────────────────────────────────────

//~ TYPE clubs : Int
public clubs : Int
let clubs = 0

//~ TYPE diamonds : Int
public diamonds : Int
let diamonds = 1

//~ TYPE hearts : Int
public hearts : Int
let hearts = 2

//~ TYPE spades : Int
public spades : Int
let spades = 3

// ── Validity predicates ───────────────────────────────────────────────────────

//~ TYPE validRank : Int -> Bool
public validRank : Int -> Bool
let validRank r = r >= 2 && r <= 14

//~ TYPE validSuit : Int -> Bool
public validSuit : Int -> Bool
let validSuit s = s >= 0 && s <= 3

//~ TYPE validCard : Int * Int -> Bool
public validCard : Int * Int -> Bool
let validCard card = validRank (rank card) && validSuit (suit card)

// ── Comparison helpers ────────────────────────────────────────────────────────

//~ TYPE sameRank : Int * Int -> Int * Int -> Bool
public sameRank : Int * Int -> Int * Int -> Bool
let sameRank a b = rank a = rank b

//~ TYPE sameSuit : Int * Int -> Int * Int -> Bool
public sameSuit : Int * Int -> Int * Int -> Bool
let sameSuit a b = suit a = suit b

//~ TYPE rankHigher : Int * Int -> Int * Int -> Bool
public rankHigher : Int * Int -> Int * Int -> Bool
let rankHigher a b = rank a > rank b

// ── Display helpers (render as Int strings for now) ───────────────────────────

//~ TYPE rankName : Int -> String
public rankName : Int -> String
let rankName r =
  if r = 11 then "J"
  else if r = 12 then "Q"
  else if r = 13 then "K"
  else if r = 14 then "A"
  else intToString r

//~ TYPE suitName : Int -> String
public suitName : Int -> String
let suitName s =
  if s = 0 then "C"
  else if s = 1 then "D"
  else if s = 2 then "H"
  else "S"

//~ TYPE cardName : Int * Int -> String
public cardName : Int * Int -> String
let cardName card = rankName (rank card) ++ suitName (suit card)

// ── Deck encoding: a card's unique index in a 52-card deck ───────────────────

//~ TYPE cardIndex : Int * Int -> Int
public cardIndex : Int * Int -> Int
let cardIndex card = (rank card - 2) * 4 + suit card

//~ TYPE indexToRank : Int -> Int
public indexToRank : Int -> Int
let indexToRank idx = idx / 4 + 2

//~ TYPE indexToSuit : Int -> Int
public indexToSuit : Int -> Int
let indexToSuit idx = idx % 4

// ── Contracts ────────────────────────────────────────────────────────────────

example: validRank ace
example: validRank two
example: validSuit clubs
example: validSuit spades
example: cardName (makeCard ace spades) = "AS"
example: cardName (makeCard two clubs) = "2C"
example: sameRank (makeCard ace spades) (makeCard ace hearts)
example: sameSuit (makeCard ace hearts) (makeCard two hearts)
example: rankHigher (makeCard ace spades) (makeCard king hearts)
example: cardIndex (makeCard two clubs) = 0
example: cardIndex (makeCard ace spades) = 51
forall r: validRank r = (r >= 2 && r <= 14)
forall s: validSuit s = (s >= 0 && s <= 3)
forall r s: validCard (makeCard r s) = (validRank r && validSuit s)
