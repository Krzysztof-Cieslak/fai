module Rational

// Exact rational arithmetic. A rational is a record with a numerator and a
// denominator, both Int. Reduction uses a recursive gcd (signatured, so
// recursion is monomorphic). The LOCAL assertions verify the inferred Int types
// of the many intermediate locals. `Rational` is a transparent alias, so public
// signatures render as the structural record (fields sorted by label, so the
// denominator prints first).

public type Rational = { num : Int, den : Int }

// ── gcd / reduction ──────────────────────────────────────────────────────────

//~ TYPE gcd : Int -> Int -> Int
//~ LOCAL gcd.a : Int
//~ LOCAL gcd.b : Int
public gcd : Int -> Int -> Int
let gcd a b = if b = 0 then a else gcd b (a % b)

//~ TYPE abs : Int -> Int
public abs : Int -> Int
let abs n = if n < 0 then 0 - n else n

//~ TYPE sign : Int -> Int
public sign : Int -> Int
let sign n = if n < 0 then 0 - 1 else if n > 0 then 1 else 0

// Reduce to lowest terms, keeping the sign on the numerator.
//~ TYPE reduce : { den : Int, num : Int } -> { den : Int, num : Int }
//~ LOCAL reduce.num : Int
//~ LOCAL reduce.den : Int
//~ LOCAL reduce.g : Int
//~ LOCAL reduce.s : Int
public reduce : Rational -> Rational
let reduce r =
  let { num, den } = r
  let g = gcd (abs num) (abs den)
  let s = sign den
  if g = 0 then r else { num = s * num / g, den = s * den / g }

// ── construction ─────────────────────────────────────────────────────────────

//~ TYPE rational : Int -> Int -> { den : Int, num : Int }
public rational : Int -> Int -> Rational
let rational num den = reduce { num = num, den = den }

//~ TYPE fromInt : Int -> { den : Int, num : Int }
public fromInt : Int -> Rational
let fromInt n = { num = n, den = 1 }

//~ TYPE numerator : { den : Int, num : Int } -> Int
public numerator : Rational -> Int
let numerator r = r.num

//~ TYPE denominator : { den : Int, num : Int } -> Int
public denominator : Rational -> Int
let denominator r = r.den

// ── arithmetic ───────────────────────────────────────────────────────────────

//~ TYPE addR : { den : Int, num : Int } -> { den : Int, num : Int } -> { den : Int, num : Int }
//~ LOCAL addR.an : Int
//~ LOCAL addR.ad : Int
//~ LOCAL addR.bn : Int
//~ LOCAL addR.bd : Int
//~ LOCAL addR.num : Int
//~ LOCAL addR.den : Int
public addR : Rational -> Rational -> Rational
let addR a b =
  let { num = an, den = ad } = a
  let { num = bn, den = bd } = b
  let num = an * bd + bn * ad
  let den = ad * bd
  reduce { num = num, den = den }

//~ TYPE subR : { den : Int, num : Int } -> { den : Int, num : Int } -> { den : Int, num : Int }
//~ LOCAL subR.num : Int
//~ LOCAL subR.den : Int
public subR : Rational -> Rational -> Rational
let subR a b =
  let { num = an, den = ad } = a
  let { num = bn, den = bd } = b
  let num = an * bd - bn * ad
  let den = ad * bd
  reduce { num = num, den = den }

//~ TYPE mulR : { den : Int, num : Int } -> { den : Int, num : Int } -> { den : Int, num : Int }
//~ LOCAL mulR.num : Int
//~ LOCAL mulR.den : Int
public mulR : Rational -> Rational -> Rational
let mulR a b =
  let { num = an, den = ad } = a
  let { num = bn, den = bd } = b
  let num = an * bn
  let den = ad * bd
  reduce { num = num, den = den }

//~ TYPE divR : { den : Int, num : Int } -> { den : Int, num : Int } -> { den : Int, num : Int }
public divR : Rational -> Rational -> Rational
let divR a b =
  let { num = an, den = ad } = a
  let { num = bn, den = bd } = b
  reduce { num = an * bd, den = ad * bn }

//~ TYPE negR : { den : Int, num : Int } -> { den : Int, num : Int }
public negR : Rational -> Rational
let negR r = { r with num = 0 - r.num }

// ── comparison ───────────────────────────────────────────────────────────────

// Compare via cross-multiplication. Returns -1, 0, or 1.
//~ TYPE compareR : { den : Int, num : Int } -> { den : Int, num : Int } -> Int
//~ LOCAL compareR.left : Int
//~ LOCAL compareR.right : Int
public compareR : Rational -> Rational -> Int
let compareR a b =
  let { num = an, den = ad } = a
  let { num = bn, den = bd } = b
  let left = an * bd
  let right = bn * ad
  if left < right then 0 - 1 else if left > right then 1 else 0

//~ TYPE equalR : { den : Int, num : Int } -> { den : Int, num : Int } -> Bool
//~ LOCAL equalR.c : Int
public equalR : Rational -> Rational -> Bool
let equalR a b =
  let c = compareR a b
  c = 0

//~ TYPE isZero : { den : Int, num : Int } -> Bool
public isZero : Rational -> Bool
let isZero r = numerator r = 0

//~ TYPE isPositive : { den : Int, num : Int } -> Bool
public isPositive : Rational -> Bool
let isPositive r = r.num * r.den > 0

// ── rendering ────────────────────────────────────────────────────────────────

//~ TYPE showR : { den : Int, num : Int } -> String
//~ LOCAL showR.n : Int
//~ LOCAL showR.d : Int
public showR : Rational -> String
let showR r =
  let { num = n, den = d } = r
  if d = 1 then Int.toString n else Int.toString n ++ "/" ++ Int.toString d

// ── Contracts ────────────────────────────────────────────────────────────────

example: gcd 12 8 = 4
example: gcd 17 5 = 1
example: reduce { num = 4, den = 8 } = { num = 1, den = 2 }
example: reduce { num = 6, den = 3 } = { num = 2, den = 1 }
example: addR { num = 1, den = 2 } { num = 1, den = 3 } = { num = 5, den = 6 }
example: subR { num = 3, den = 4 } { num = 1, den = 4 } = { num = 1, den = 2 }
example: mulR { num = 2, den = 3 } { num = 3, den = 4 } = { num = 1, den = 2 }
example: divR { num = 1, den = 2 } { num = 1, den = 4 } = { num = 2, den = 1 }
example: equalR { num = 1, den = 2 } { num = 2, den = 4 }
example: compareR { num = 1, den = 3 } { num = 1, den = 2 } = 0 - 1
example: showR { num = 3, den = 1 } = "3"
example: showR { num = 1, den = 2 } = "1/2"
example: isZero { num = 0, den = 5 }
forall n: reduce { num = n, den = 1 } = { num = n, den = 1 }
forall a b: mulR a b = mulR b a
