module Rational

// Exact rational arithmetic. A rational is a pair (numerator, denominator),
// both Int. Reduction uses a recursive gcd (signatured, so recursion is
// monomorphic). The LOCAL assertions verify the inferred Int types of the many
// intermediate locals.

// ── gcd / reduction ──────────────────────────────────────────────────────────

//~ TYPE gcd : Int -> Int -> Int
//~ LOCAL gcd.a : Int
//~ LOCAL gcd.b : Int
public gcd : Int -> Int -> Int
let gcd a b = if b = 0 then a else gcd b (a % b)

//~ TYPE abs : Int -> Int
public abs : Int -> Int
let abs n = if n < 0 then 0 - n else n

//~ TYPE sign : Int -> Int
public sign : Int -> Int
let sign n = if n < 0 then 0 - 1 else if n > 0 then 1 else 0

// Reduce to lowest terms, keeping the sign on the numerator.
//~ TYPE reduce : Int * Int -> Int * Int
//~ LOCAL reduce.num : Int
//~ LOCAL reduce.den : Int
//~ LOCAL reduce.g : Int
//~ LOCAL reduce.s : Int
public reduce : Int * Int -> Int * Int
let reduce r =
  let (num, den) = r
  let g = gcd (abs num) (abs den)
  let s = sign den
  if g = 0 then (num, den) else (s * num / g, s * den / g)

// ── construction ─────────────────────────────────────────────────────────────

//~ TYPE rational : Int -> Int -> Int * Int
public rational : Int -> Int -> Int * Int
let rational num den = reduce (num, den)

//~ TYPE fromInt : Int -> Int * Int
public fromInt : Int -> Int * Int
let fromInt n = (n, 1)

//~ TYPE numerator : Int * Int -> Int
public numerator : Int * Int -> Int
let numerator r =
  let (n, d) = r
  n

//~ TYPE denominator : Int * Int -> Int
public denominator : Int * Int -> Int
let denominator r =
  let (n, d) = r
  d

// ── arithmetic ───────────────────────────────────────────────────────────────

//~ TYPE addR : Int * Int -> Int * Int -> Int * Int
//~ LOCAL addR.an : Int
//~ LOCAL addR.ad : Int
//~ LOCAL addR.bn : Int
//~ LOCAL addR.bd : Int
//~ LOCAL addR.num : Int
//~ LOCAL addR.den : Int
public addR : Int * Int -> Int * Int -> Int * Int
let addR a b =
  let (an, ad) = a
  let (bn, bd) = b
  let num = an * bd + bn * ad
  let den = ad * bd
  reduce (num, den)

//~ TYPE subR : Int * Int -> Int * Int -> Int * Int
//~ LOCAL subR.num : Int
//~ LOCAL subR.den : Int
public subR : Int * Int -> Int * Int -> Int * Int
let subR a b =
  let (an, ad) = a
  let (bn, bd) = b
  let num = an * bd - bn * ad
  let den = ad * bd
  reduce (num, den)

//~ TYPE mulR : Int * Int -> Int * Int -> Int * Int
//~ LOCAL mulR.num : Int
//~ LOCAL mulR.den : Int
public mulR : Int * Int -> Int * Int -> Int * Int
let mulR a b =
  let (an, ad) = a
  let (bn, bd) = b
  let num = an * bn
  let den = ad * bd
  reduce (num, den)

//~ TYPE divR : Int * Int -> Int * Int -> Int * Int
public divR : Int * Int -> Int * Int -> Int * Int
let divR a b =
  let (an, ad) = a
  let (bn, bd) = b
  reduce (an * bd, ad * bn)

//~ TYPE negR : Int * Int -> Int * Int
public negR : Int * Int -> Int * Int
let negR r =
  let (n, d) = r
  (0 - n, d)

// ── comparison ───────────────────────────────────────────────────────────────

// Compare via cross-multiplication. Returns -1, 0, or 1.
//~ TYPE compareR : Int * Int -> Int * Int -> Int
//~ LOCAL compareR.left : Int
//~ LOCAL compareR.right : Int
public compareR : Int * Int -> Int * Int -> Int
let compareR a b =
  let (an, ad) = a
  let (bn, bd) = b
  let left = an * bd
  let right = bn * ad
  if left < right then 0 - 1 else if left > right then 1 else 0

//~ TYPE equalR : Int * Int -> Int * Int -> Bool
//~ LOCAL equalR.c : Int
public equalR : Int * Int -> Int * Int -> Bool
let equalR a b =
  let c = compareR a b
  c = 0

//~ TYPE isZero : Int * Int -> Bool
public isZero : Int * Int -> Bool
let isZero r = numerator r = 0

//~ TYPE isPositive : Int * Int -> Bool
public isPositive : Int * Int -> Bool
let isPositive r =
  let (n, d) = r
  n * d > 0

// ── rendering ────────────────────────────────────────────────────────────────

//~ TYPE showR : Int * Int -> String
//~ LOCAL showR.n : Int
//~ LOCAL showR.d : Int
public showR : Int * Int -> String
let showR r =
  let (n, d) = r
  if d = 1 then intToString n else intToString n ++ "/" ++ intToString d

// ── Contracts ────────────────────────────────────────────────────────────────

example: gcd 12 8 = 4
example: gcd 17 5 = 1
example: reduce (4, 8) = (1, 2)
example: reduce (6, 3) = (2, 1)
example: addR (1, 2) (1, 3) = (5, 6)
example: subR (3, 4) (1, 4) = (1, 2)
example: mulR (2, 3) (3, 4) = (1, 2)
example: divR (1, 2) (1, 4) = (2, 1)
example: equalR (1, 2) (2, 4)
example: compareR (1, 3) (1, 2) = 0 - 1
example: showR (3, 1) = "3"
example: showR (1, 2) = "1/2"
example: isZero (0, 5)
forall n: reduce (n, 1) = (n, 1)
forall a b: mulR a b = mulR b a
