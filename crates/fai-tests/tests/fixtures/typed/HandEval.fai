module HandEval

// Evaluation of 5-card poker hands. A hand is a `List Card`, and the hand
// categories are an algebraic data type declared from weakest to strongest, so
// the *structural* ordering (`<`, `>`) ranks them with no numeric encoding. The
// detectors lean on the prelude list combinators (`map`, `filter`, `all`,
// `foldl`, `sort`), and `match` drives the category names. `Card` is a
// transparent alias, so `List Card` renders as the structural record list.

type Suit =
  | Clubs
  | Diamonds
  | Hearts
  | Spades

type Rank =
  | Two
  | Three
  | Four
  | Five
  | Six
  | Seven
  | Eight
  | Nine
  | Ten
  | Jack
  | Queen
  | King
  | Ace

type Card = { rank : Rank, suit : Suit }

type HandCategory =
  | HighCard
  | Pair
  | TwoPair
  | ThreeOfAKind
  | Straight
  | Flush
  | FullHouse
  | FourOfAKind
  | StraightFlush
  | RoyalFlush

//~ TYPE card : Rank -> Suit -> { rank : Rank, suit : Suit }
public card : Rank -> Suit -> Card
let card r s = { rank = r, suit = s }

//~ TYPE rankValue : Rank -> Int
public rankValue : Rank -> Int
let rankValue r =
  match r with
  | Two -> 2
  | Three -> 3
  | Four -> 4
  | Five -> 5
  | Six -> 6
  | Seven -> 7
  | Eight -> 8
  | Nine -> 9
  | Ten -> 10
  | Jack -> 11
  | Queen -> 12
  | King -> 13
  | Ace -> 14

// ── Projections ──────────────────────────────────────────────────────────────

//~ TYPE ranks : List { rank : Rank, suit : Suit } -> List Int
public ranks : List Card -> List Int
let ranks hand = map (fun c -> rankValue c.rank) hand

//~ TYPE suits : List { rank : Rank, suit : Suit } -> List Suit
public suits : List Card -> List Suit
let suits hand = map (fun c -> c.suit) hand

// ── Private counting helpers ─────────────────────────────────────────────────

// How many entries of `rs` equal `v`.
let countOf v rs = length (filter (fun x -> x = v) rs)

// The largest value in `xs` (0 when empty; ranks are always >= 2).
let maximum xs = foldl (fun acc x -> if x > acc then x else acc) 0 xs

// Whether the sorted list steps up by exactly one at each position.
let consecutive xs =
  match xs with
  | [] -> true
  | x :: rest ->
    match rest with
    | [] -> true
    | y :: _ -> if y = x + 1 then consecutive rest else false

// ── Shape detectors ──────────────────────────────────────────────────────────

// A flush: every card shares the first card's suit.
//~ TYPE isFlush : List { rank : Rank, suit : Suit } -> Bool
public isFlush : List Card -> Bool
let isFlush hand =
  match suits hand with
  | [] -> false
  | s :: rest -> all (fun x -> x = s) rest

// A straight: the ranks form five consecutive values.
//~ TYPE isStraight : List { rank : Rank, suit : Suit } -> Bool
public isStraight : List Card -> Bool
let isStraight hand = consecutive (sort (ranks hand))

// The size of the largest same-rank group (1..4).
//~ TYPE maxCount : List Int -> Int
public maxCount : List Int -> Int
let maxCount rs = foldl (fun acc v -> if countOf v rs > acc then countOf v rs else acc) 0 rs

// The number of ranks that appear exactly twice.
//~ TYPE pairCount : List Int -> Int
public pairCount : List Int -> Int
let pairCount rs = length (filter (fun v -> countOf v rs = 2) rs) / 2

// ── Classification ───────────────────────────────────────────────────────────

//~ TYPE classify : List { rank : Rank, suit : Suit } -> HandCategory
public classify : List Card -> HandCategory
let classify hand =
  let rs = ranks hand
  let flush = isFlush hand
  let straight = isStraight hand
  let mc = maxCount rs
  let pc = pairCount rs
  if flush && straight then (if maximum rs = 14 then RoyalFlush else StraightFlush)
  else if mc = 4 then FourOfAKind
  else if mc = 3 && pc >= 1 then FullHouse
  else if flush then Flush
  else if straight then Straight
  else if mc = 3 then ThreeOfAKind
  else if pc = 2 then TwoPair
  else if pc = 1 then Pair
  else HighCard

//~ TYPE handName : HandCategory -> String
public handName : HandCategory -> String
let handName c =
  match c with
  | HighCard -> "High Card"
  | Pair -> "Pair"
  | TwoPair -> "Two Pair"
  | ThreeOfAKind -> "Three of a Kind"
  | Straight -> "Straight"
  | Flush -> "Flush"
  | FullHouse -> "Full House"
  | FourOfAKind -> "Four of a Kind"
  | StraightFlush -> "Straight Flush"
  | RoyalFlush -> "Royal Flush"

// Whether category `a` beats category `b` (structural ordering on the enum).
//~ TYPE beats : HandCategory -> HandCategory -> Bool
public beats : HandCategory -> HandCategory -> Bool
let beats a b = a > b

// ── Contracts ────────────────────────────────────────────────────────────────

let royalFlush = [card Ace Spades, card King Spades, card Queen Spades, card Jack Spades, card Ten Spades]
let fourAces = [card Ace Spades, card Ace Hearts, card Ace Diamonds, card Ace Clubs, card Two Clubs]
let fullHouseHand = [card Ace Spades, card Ace Hearts, card Ace Diamonds, card King Spades, card King Hearts]
let flushHand = [card Two Spades, card Five Spades, card Seven Spades, card Nine Spades, card Jack Spades]
let straightHand = [card Five Clubs, card Six Diamonds, card Seven Hearts, card Eight Spades, card Nine Clubs]
let pairHand = [card Ace Spades, card Ace Hearts, card Two Clubs, card Three Clubs, card Four Clubs]

example: isFlush royalFlush
example: isStraight royalFlush
example: classify royalFlush = RoyalFlush
example: classify fourAces = FourOfAKind
example: classify fullHouseHand = FullHouse
example: classify flushHand = Flush
example: classify straightHand = Straight
example: classify pairHand = Pair
example: handName FourOfAKind = "Four of a Kind"
example: handName HighCard = "High Card"
example: beats StraightFlush FullHouse
example: FullHouse > Flush
forall a: beats a a = false
