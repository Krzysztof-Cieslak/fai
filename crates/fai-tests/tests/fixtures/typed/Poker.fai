module Poker

// Texas Hold'em betting and pot management. The game state is a record, player
// actions are an algebraic data type matched by name, and a showdown yields an
// `Outcome` rather than a magic integer. `Game` is a transparent alias, so
// public signatures render as the structural record (fields sorted by label).

type Game =
  { pot : Int, smallBlind : Int, bigBlind : Int, currentBet : Int, button : Int }

type Action =
  | Fold
  | Check
  | Call
  | Raise
  | AllIn

type Outcome =
  | PlayerA
  | PlayerB
  | Split

// ── Accessors ────────────────────────────────────────────────────────────────

//~ TYPE smallBlindAmount : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int
public smallBlindAmount : Game -> Int
let smallBlindAmount game = game.smallBlind

//~ TYPE bigBlindAmount : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int
public bigBlindAmount : Game -> Int
let bigBlindAmount game = game.bigBlind

//~ TYPE currentBet : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int
public currentBet : Game -> Int
let currentBet game = game.currentBet

//~ TYPE pot : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int
public pot : Game -> Int
let pot game = game.pot

//~ TYPE buttonPosition : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int
public buttonPosition : Game -> Int
let buttonPosition game = game.button

// ── Game construction ─────────────────────────────────────────────────────────

//~ TYPE newGame : Int -> Int -> Int -> { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int }
public newGame : Int -> Int -> Int -> Game
let newGame smallBlind bigBlind button =
  { pot = 0, smallBlind = smallBlind, bigBlind = bigBlind, currentBet = bigBlind, button = button }

//~ TYPE validGame : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Bool
public validGame : Game -> Bool
let validGame game =
  game.smallBlind > 0 && game.bigBlind = game.smallBlind * 2 && game.pot >= 0 && game.currentBet >= 0

// ── Stack management ──────────────────────────────────────────────────────────

//~ TYPE totalChips : List Int -> Int
public totalChips : List Int -> Int
let totalChips stacks = List.sum stacks

//~ TYPE playerCount : List Int -> Int
public playerCount : List Int -> Int
let playerCount stacks = List.length stacks

//~ TYPE isEliminated : List Int -> Int -> Bool
public isEliminated : List Int -> Int -> Bool
let isEliminated stacks idx = idx < 0 || idx >= List.length stacks

//~ TYPE activePlayers : List Int -> Int
public activePlayers : List Int -> Int
let activePlayers stacks = List.length (List.filter (fun s -> s > 0) stacks)

// ── Betting actions ───────────────────────────────────────────────────────────

// The cost to call: the difference between the current bet and the player's bet.
//~ TYPE callAmount : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int -> Int
public callAmount : Game -> Int -> Int
let callAmount game playerBet =
  let cb = game.currentBet
  if cb > playerBet then cb - playerBet else 0

// A raise to `targetAmount` from a player whose current bet is `playerBet`.
//~ TYPE raiseAmount : Int -> Int -> Int
public raiseAmount : Int -> Int -> Int
let raiseAmount targetAmount playerBet =
  if targetAmount > playerBet then targetAmount - playerBet else 0

// Whether a player with `stack` chips can afford to call.
//~ TYPE canCall : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int -> Int -> Bool
public canCall : Game -> Int -> Int -> Bool
let canCall game stack playerBet = stack >= callAmount game playerBet

// Whether a raise to `amount` clears the current bet plus a big-blind min-raise.
//~ TYPE isValidRaise : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int -> Bool
public isValidRaise : Game -> Int -> Bool
let isValidRaise game amount = amount >= game.currentBet + game.bigBlind

// Add a bet to the pot, returning a new game state with an updated pot and bet.
//~ TYPE addToPot : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int -> Int -> { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int }
public addToPot : Game -> Int -> Int -> Game
let addToPot game amount newBet = { game with pot = game.pot + amount, currentBet = newBet }

// Post the small blind.
//~ TYPE postSmallBlind : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int }
public postSmallBlind : Game -> Game
let postSmallBlind game = addToPot game game.smallBlind game.smallBlind

// Post the big blind.
//~ TYPE postBigBlind : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int }
public postBigBlind : Game -> Game
let postBigBlind game = addToPot game game.bigBlind game.bigBlind

// ── Pot odds and equity estimation ───────────────────────────────────────────

// Pot odds as a percentage (call / (pot + call) * 100), integer arithmetic.
//~ TYPE potOddsPercent : Int -> Int -> Int
public potOddsPercent : Int -> Int -> Int
let potOddsPercent potSize callAmt =
  if callAmt = 0 then 0
  else callAmt * 100 / (potSize + callAmt)

// Whether the pot odds are favourable given an estimated equity in percent.
//~ TYPE isFavourableCall : Int -> Int -> Int -> Bool
public isFavourableCall : Int -> Int -> Int -> Bool
let isFavourableCall potSize callAmt equityPct = equityPct > potOddsPercent potSize callAmt

// The break-even equity needed to call.
//~ TYPE breakEvenEquity : Int -> Int -> Int
public breakEvenEquity : Int -> Int -> Int
let breakEvenEquity potSize callAmt = potOddsPercent potSize callAmt

// ── Round management ──────────────────────────────────────────────────────────

// Move the button to the next player (wraps around).
//~ TYPE advanceButton : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> Int -> { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int }
public advanceButton : Game -> Int -> Game
let advanceButton game numPlayers =
  let nextButton = if game.button + 1 >= numPlayers then 0 else game.button + 1
  { game with button = nextButton }

// Reset for a new hand: clear the pot and reset the current bet to the big blind.
//~ TYPE newHand : { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int } -> { bigBlind : Int, button : Int, currentBet : Int, pot : Int, smallBlind : Int }
public newHand : Game -> Game
let newHand game = { game with pot = 0, currentBet = game.bigBlind }

// ── Side pot calculation (two-player all-in scenario) ────────────────────────

// Heads-up all-in: the main pot is twice the smaller stack.
//~ TYPE mainPotAllIn : Int -> Int -> Int
public mainPotAllIn : Int -> Int -> Int
let mainPotAllIn stackA stackB =
  let minStack = if stackA < stackB then stackA else stackB
  minStack * 2

// The excess returned to the larger stack as a side pot.
//~ TYPE sidePotAllIn : Int -> Int -> Int
public sidePotAllIn : Int -> Int -> Int
let sidePotAllIn stackA stackB =
  if stackA > stackB then stackA - stackB else stackB - stackA

// ── Showdown ──────────────────────────────────────────────────────────────────

// Compare two hand ranks with a kicker for ties, yielding the winner.
//~ TYPE showdown : Int -> Int -> Int -> Int -> Outcome
public showdown : Int -> Int -> Int -> Int -> Outcome
let showdown rankA kickerA rankB kickerB =
  if rankA > rankB then PlayerA
  else if rankB > rankA then PlayerB
  else if kickerA > kickerB then PlayerA
  else if kickerB > kickerA then PlayerB
  else Split

//~ TYPE winnerName : Outcome -> String
public winnerName : Outcome -> String
let winnerName outcome =
  match outcome with
  | PlayerA -> "Player A wins"
  | PlayerB -> "Player B wins"
  | Split -> "Split pot"

// ── Rake calculation ──────────────────────────────────────────────────────────

// Standard 5% rake, capped at a maximum (integer arithmetic; amounts in chips).
//~ TYPE rake : Int -> Int -> Int
public rake : Int -> Int -> Int
let rake potSize cap =
  let fivePct = potSize * 5 / 100
  if fivePct > cap then cap else fivePct

//~ TYPE netPot : Int -> Int -> Int
public netPot : Int -> Int -> Int
let netPot potSize cap = potSize - rake potSize cap

// ── Player actions ────────────────────────────────────────────────────────────

//~ TYPE describeAction : Action -> String
public describeAction : Action -> String
let describeAction action =
  match action with
  | Fold -> "fold"
  | Check -> "check"
  | Call -> "call"
  | Raise -> "raise"
  | AllIn -> "all-in"

//~ TYPE isBettingAction : Action -> Bool
public isBettingAction : Action -> Bool
let isBettingAction action =
  match action with
  | Fold -> false
  | Check -> false
  | Call -> true
  | Raise -> true
  | AllIn -> true

// ── Contracts ────────────────────────────────────────────────────────────────

let g1 = newGame 5 10 0

example: smallBlindAmount g1 = 5
example: bigBlindAmount g1 = 10
example: pot g1 = 0
example: currentBet g1 = 10
example: buttonPosition g1 = 0
example: validGame g1
example: callAmount g1 0 = 10
example: callAmount g1 10 = 0
example: pot (postSmallBlind g1) = 5
example: potOddsPercent 90 10 = 10
example: isFavourableCall 90 10 30
example: rake 100 5 = 5
example: rake 200 5 = 5
example: netPot 100 5 = 95
example: mainPotAllIn 100 80 = 160
example: sidePotAllIn 100 80 = 20
example: showdown 7 14 6 14 = PlayerA
example: showdown 6 14 7 14 = PlayerB
example: showdown 5 14 5 10 = PlayerA
example: winnerName PlayerA = "Player A wins"
example: describeAction Fold = "fold"
example: describeAction Call = "call"
example: isBettingAction Call
example: not (isBettingAction Fold)
forall sb: validGame (newGame sb (sb * 2) 0) = (sb > 0)
forall p callAmt: potOddsPercent p callAmt >= 0
forall a b: showdown a 14 b 14 = (if a > b then PlayerA else if b > a then PlayerB else Split)
