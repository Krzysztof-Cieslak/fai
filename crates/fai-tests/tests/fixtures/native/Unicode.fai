module Unicode

// Multibyte UTF-8 (and an escape) round-tripping through the lexer, the static
// string data, the runtime, and stdout.
let banner = "héllo, 世界 \u{1F600}"

let line s = "<< " ++ s ++ " >>"

public main : Runtime -> Unit
let main runtime =
  let a = runtime.console.writeLine banner
  runtime.console.writeLine (line "café")

//~ OUTPUT héllo, 世界 😀
//~ OUTPUT << café >>
