module Collatz

let step n = if n % 2 = 0 then n / 2 else 3 * n + 1

let steps n acc = if n <= 1 then acc else steps (step n) (acc + 1)

let collatz n = steps n 0

public main : Runtime -> Unit
let main runtime =
  let a = runtime.console.writeLine (Int.toString (collatz 6))
  let b = runtime.console.writeLine (Int.toString (collatz 27))
  runtime.console.writeLine (Int.toString (collatz 1))

//~ OUTPUT 8
//~ OUTPUT 111
//~ OUTPUT 0
