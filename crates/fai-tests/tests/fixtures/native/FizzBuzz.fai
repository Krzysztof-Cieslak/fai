module FizzBuzz

let classify n =
  if n % 15 = 0 then "FizzBuzz"
  else if n % 3 = 0 then "Fizz"
  else if n % 5 = 0 then "Buzz"
  else intToString n

// A recursive print loop threading the runtime capability.
let loop runtime i n =
  if i > n then ()
  else
    let printed = Console.writeLine runtime (classify i)
    loop runtime (i + 1) n

public main : Runtime -> Unit
let main runtime = loop runtime 1 15

