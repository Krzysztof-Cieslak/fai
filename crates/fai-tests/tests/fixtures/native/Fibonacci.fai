module Fibonacci

// Naive exponential recursion.
let fib n = if n < 2 then n else fib (n - 1) + fib (n - 2)

// Linear accumulator recursion (top-level so it can recurse).
let fibIter i a b = if i = 0 then a else fibIter (i - 1) b (a + b)

let fastFib n = fibIter n 0 1

public main : Runtime -> Unit
let main runtime =
  let a = Console.writeLine runtime (Int.toString (fib 10))
  let b = Console.writeLine runtime (Int.toString (fastFib 20))
  Console.writeLine runtime (Int.toString (fastFib 30))

//~ OUTPUT 55
//~ OUTPUT 6765
//~ OUTPUT 832040
