module Ackermann

// Deeply nested recursion (ack 3 3 makes a few thousand calls).
let ack m n =
  if m = 0 then n + 1
  else if n = 0 then ack (m - 1) 1
  else ack (m - 1) (ack m (n - 1))

public main : Runtime -> Unit
let main runtime =
  let a = Console.writeLine runtime (intToString (ack 2 3))
  let b = Console.writeLine runtime (intToString (ack 3 3))
  Console.writeLine runtime (intToString (ack 2 5))

//~ OUTPUT 9
//~ OUTPUT 61
//~ OUTPUT 13
