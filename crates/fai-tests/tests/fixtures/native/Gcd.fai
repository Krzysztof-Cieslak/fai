module Gcd

let gcd a b = if b = 0 then a else gcd b (a % b)

let lcm a b = a / gcd a b * b

public main : Runtime -> Unit / { Console }
let main runtime =
  let a = runtime.console.writeLine (Int.toString (gcd 48 36))
  let b = runtime.console.writeLine (Int.toString (gcd 17 5))
  runtime.console.writeLine (Int.toString (lcm 4 6))

//~ OUTPUT 12
//~ OUTPUT 1
//~ OUTPUT 12
